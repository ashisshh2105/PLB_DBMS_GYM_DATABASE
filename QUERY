-- 8
SELECT w.exercise_name, d.calories_target
FROM Workout w, Diet d
WHERE w.member_id = d.member_id;

-- 9
SELECT m.manager_name, e.equipment_name
FROM Manager m, Trainer t, Equipment_Maintenance e
WHERE m.manager_id = t.manager_id 
AND t.trainer_id = e.trainer_id;

-- 10
SELECT m.name, p.payment_date
FROM Member m, Payment p
WHERE m.member_id = p.member_id;

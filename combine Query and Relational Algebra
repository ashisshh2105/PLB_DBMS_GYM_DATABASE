#1 Retrieve all unique specializations of members.
SELECT DISTINCT specialization FROM Member;
#(RA) π specialization (Member)


#2 Retrieve names of all owners.
SELECT owner_name FROM An_Owner; 
 
 #(RA) π owner_name (An_Owner)
 
 #3 Retrieve all managers under owner with ID = 1.
 SELECT * FROM Manager WHERE owner_id = 1;
 
 #(RA) σ owner_id = 1 (Manager)
 
 #4 Retrieve trainers with more than 3 years of experience
 SELECT * FROM Trainer WHERE experience_year > 3;
 
 #(RA) σ experience_year > 3 (Trainer)
 
#5 Retrieve all completed payments.
SELECT * FROM Payment 
WHERE transaction_status = 'Completed';

#(RA) σ transaction_status = 'Completed' (Payment)

#6 Retrieve all active memberships
SELECT * FROM Membership WHERE status = 'Active';

 #(RA) σ status = 'Active' (Membership)
 
 #7 Retrieve all workout types of members.
 SELECT exercise_name FROM Workout where difficulty ='hard';
 
 #(RA) π exercise_name ( σ difficulty = 'hard' (Workout) )
 
 #8 Retrieve exercise names and diet plans for members.
SELECT w.exercise_name, d.calories_target
FROM Workout w, Diet d
WHERE w.member_id = d.member_id;
 
  #(RA) π exercise_name, calories_target ( Workout ⨝ Diet )
  
  #9 Retrieve manager names along with equipment handled by trainers under them.
  SELECT m.manager_name, e.equipment_name
FROM Manager m, Trainer t, Equipment_Maintenance e
WHERE m.manager_id = t.manager_id 
AND t.trainer_id = e.trainer_id; 

#(RA) π manager_name, equipment_name ( Manager ⨝ Trainer ⨝ Equipment_Maintenance )

# 10 Retrieve member names and payment dates.
SELECT m.name, p.payment_date
FROM Member m, Payment p
WHERE m.member_id = p.member_id; 
 
 #(RA) π name, payment_date ( Member ⨝ Payment )
 

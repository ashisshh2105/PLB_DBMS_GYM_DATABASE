#1Owner + Manager (kaunsa manager kis owner ke under hai)
SELECT o.owner_name, m.manager_name
FROM An_Owner o, Manager m
WHERE o.owner_id = m.owner_id;

#(RA) π owner_name, manager_name ( An_Owner ⨝ Manager )

#2Member + Payment (kis member ne kab payment kiya)
SELECT m.name, p.payment_date
FROM Member m, Payment p
WHERE m.member_id = p.member_id;
# (RA) π name, payment_date ( Member ⨝ Payment )

# 3Member + Manager (kaunsa member kis manager ke under hai)
SELECT m.name, mg.manager_name
FROM Member m, Manager mg
WHERE m.manager_id = mg.manager_id;
#(RA)π name, manager_name ( Member ⨝ Manager ) 

#4Group By (Specialization wise count)Number of members in each specialization
SELECT specialization, COUNT(*) AS total
FROM Member
GROUP BY specialization;
# RA -  γ specialization, COUNT(member_id) (Member)

#5 Count trainers under each manager
SELECT manager_id, COUNT(*) AS total_trainers
FROM Trainer
GROUP BY manager_id;
# RA - γ manager_id, COUNT(trainer_id) (Trainer)

#6 Member + Workout + Diet
SELECT m.name, w.exercise_name, d.calories_target
FROM Member m, Workout w, Diet d
WHERE m.member_id = w.member_id
AND m.member_id = d.member_id;

# π name, exercise_name, calories_target( Member ⨝ Workout ⨝ Diet )


#7Manager + Member + Trainer
SELECT mg.manager_name, m.name, t.name
FROM Manager mg, Member m, Trainer t
WHERE mg.manager_id = m.manager_id
AND mg.manager_id = t.manager_id;

# π manager_name, member_name, trainer_name( Manager ⨝ Member ⨝ Trainer )

#8 Card payments that are completed
SELECT * FROM Payment
WHERE mode = 'Card' AND transaction_status = 'Completed';

# RA σ mode = 'Card' ∧ transaction_status = 'Completed' (Payment)

#9 Members with calories < 2000
SELECT * FROM Diet
WHERE calories_target < 2000;

#(RA)σ calories_target < 2000 (Diet)

#10 Equipment handled by experienced trainers (>3 years)
SELECT e.equipment_name, t.name
FROM Equipment_Maintenance e, Trainer t
WHERE e.trainer_id = t.trainer_id
AND t.experience_year > 3;

#π equipment_name, trainer_name( σ experience_year > 3 ( Equipment_Maintenance ⨝ Trainer ) )



CREATE DATABASE Gym_Management_System;
USE Gym_Management_System;
# 1 OWNER TABLE( TOP LEVEL)
CREATE TABLE An_Owner (
    owner_id INT PRIMARY KEY AUTO_INCREMENT,
    owner_name VARCHAR(100)
);
DESC AN_OWNER;
 SELECT * FROM an_owner;
#2 MANAGER(UNDER OWNER)
CREATE TABLE Manager (
    manager_id INT PRIMARY KEY AUTO_INCREMENT,
    manager_name VARCHAR(100),
    email VARCHAR(100),
    owner_id INT,
    FOREIGN KEY (owner_id) REFERENCES An_Owner(owner_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);
DESC MANAGER;
#3 MEMBER( UNDER MANAGER) 
CREATE TABLE Member (
    member_id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL,
      phone_number VARCHAR(15),
    specialization VARCHAR(100),
    manager_id INT,
    FOREIGN KEY (manager_id) REFERENCES Manager(manager_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
DESC member ;
select * from member;
# 4 TRAINER (UNDER MANAGER)
drop table trainer;
CREATE TABLE Trainer (
    trainer_id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100),
    specialization VARCHAR(100),
    experience_year INT,
    certification VARCHAR(100),
    join_date DATE,
    manager_id INT,
    FOREIGN KEY (manager_id) REFERENCES Manager(manager_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);

-- DERIVED VIEW → Trainer Experience
CREATE VIEW Trainer_Experience AS
SELECT 
    trainer_id,
    name,
    TIMESTAMPDIFF(YEAR, join_date, CURDATE()) AS experience_years
FROM Trainer;

-- 5 MEMBERSHIP (UNDER MEMBER)
CREATE TABLE Membership (
    membership_id INT PRIMARY KEY AUTO_INCREMENT,
    start_date DATE,
    status VARCHAR(50),
    member_id INT,
    payment_id INT,

    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE,

    FOREIGN KEY (payment_id) REFERENCES Payment(payment_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);
-- 6 PAYMENT (UNDER MEMBER)
CREATE TABLE Payment (
    payment_id INT PRIMARY KEY AUTO_INCREMENT,
    payment_date DATE,
    mode VARCHAR(50),
    transaction_status VARCHAR(50),
    member_id INT,
    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

-- DERIVED VIEW → Total Payments
CREATE VIEW Member_Total_Payments AS
SELECT 
    member_id,
    COUNT(payment_id) AS total_payments
FROM Payment
GROUP BY member_id;

-- 7 WORKOUT (MEMBER + TRAINER)
CREATE TABLE Workout (
    workout_id INT PRIMARY KEY AUTO_INCREMENT,
    difficulty VARCHAR(50),
    status VARCHAR(50),
    exercise_name VARCHAR(100),
    member_id INT,
    trainer_id INT,
    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    FOREIGN KEY (trainer_id) REFERENCES Trainer(trainer_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);

-- DERIVED VIEW → Workout Count
CREATE VIEW Member_Workout_Count AS
SELECT 
    member_id,
    COUNT(workout_id) AS total_workouts
FROM Workout
GROUP BY member_id;

-- 8 DIET (MEMBER + TRAINER)
CREATE TABLE Diet (
    diet_id INT PRIMARY KEY AUTO_INCREMENT,
    calories_target INT,
    member_id INT,
    trainer_id INT,
    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    FOREIGN KEY (trainer_id) REFERENCES Trainer(trainer_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);

-- 9 EQUIPMENT MAINTENANCE
CREATE TABLE Equipment_Maintenance (
    maintenance_id INT PRIMARY KEY AUTO_INCREMENT,
    equipment_name VARCHAR(100),
    condition_status VARCHAR(100),
    last_service_date DATE,
    incident_date DATE,
    trainer_id INT,
    FOREIGN KEY (trainer_id) REFERENCES Trainer(trainer_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);

CREATE DATABASE Gym_Management_System;
USE Gym_Management_System;
# 1 OWNER TABLE( TOP LEVEL)
CREATE TABLE An_Owner (
    owner_id INT PRIMARY KEY AUTO_INCREMENT,
    owner_name VARCHAR(100)
);
SHOW CREATE TABLE AN_OWNER;
DESC AN_OWNER;
 SELECT * FROM an_owner;
#2 MANAGER(UNDER OWNER)
CREATE TABLE Manager (
    manager_id INT PRIMARY KEY AUTO_INCREMENT,
    manager_name VARCHAR(100),
    owner_id INT,
    FOREIGN KEY (owner_id) REFERENCES An_Owner(owner_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);
DESC MANAGER;
#3 MEMBER( UNDER MANAGER) 
CREATE TABLE Member (
    member_id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL,
    specialization VARCHAR(100),
    manager_id INT,
    FOREIGN KEY (manager_id) REFERENCES Manager(manager_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
DESC member ;
select * from member;
# 4 TRAINER (UNDER MANAGER)
CREATE TABLE Trainer (
    trainer_id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100),
    specialization VARCHAR(100),
    experience INT,
    manager_id INT,
    FOREIGN KEY (manager_id) REFERENCES Manager(manager_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
 DESC TRAINER;
Select * from trainer;
# 5 MEMBERSHIP (UNDER MEMBER ,FOR ALL THE MEMBER IN GYM)
CREATE TABLE Membership (
    membership_id INT PRIMARY KEY AUTO_INCREMENT,
    start_date DATE,
    status VARCHAR(50),
    member_id INT,
    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);
DESC MEMBERSHIP;
 SELECT * FROM membership;
#6 PAYMENT (UNDER MEMBER)
CREATE TABLE Payment (
    payment_id INT AUTO_INCREMENT,
    payment_date DATE,
    mode VARCHAR(50),
    member_id INT,
    PRIMARY KEY (payment_id),
    CONSTRAINT fk_member
        FOREIGN KEY (member_id)
        REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);
DESC Table Payment ;
SELECT * FROM Payment;
#7 WORKOUT (MEMBER AND TRAINER ,BOTH ARE CONNECTED)
CREATE TABLE Workout (
    workout_id INT PRIMARY KEY AUTO_INCREMENT,
    difficulty VARCHAR(50),
    status VARCHAR(50),
    member_id INT,
    trainer_id INT,
    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    FOREIGN KEY (trainer_id) REFERENCES Trainer(trainer_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
DESC workout;
SELECT * FROM workout;
# 8 WORKOUT PLAN (UNDER TRAINER)
CREATE TABLE Workout_Plan (
    plan_id INT PRIMARY KEY AUTO_INCREMENT,
    start_date DATE,
    status VARCHAR(50),
    trainer_id INT,
    FOREIGN KEY (trainer_id) REFERENCES Trainer(trainer_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
DESC Table workout_plan;
 SELECT * FROM workout_plan;
#9 DIET( CONNECTED WITH MEMBER AND TRAINER
CREATE TABLE Diet (
    diet_id INT PRIMARY KEY AUTO_INCREMENT,
    calories_target INT,
    member_id INT,
    trainer_id INT,
    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    FOREIGN KEY (trainer_id) REFERENCES Trainer(trainer_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
  DESC Table diet;
SELECT * FROM diet;
#10 SUPPLEMENTS( UNDER MEMBER)
CREATE TABLE Supplements (
    supplement_id INT PRIMARY KEY AUTO_INCREMENT,
    body_fat FLOAT,
    dosage VARCHAR(100),
    start_date DATE,
    member_id INT,
    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);
DESC Table supplements;
SELECT * FROM supplements;
#11 EQUIPMENT MAINTENANCE( CONNECTED WITH THE TRAINER)
CREATE TABLE Equipment_Maintenance (
    maintenance_id INT PRIMARY KEY AUTO_INCREMENT,
    equipment_name VARCHAR(100),
    condition_status VARCHAR(100),
    last_service_date DATE,
    incident_date DATE,
    trainer_id INT,
    FOREIGN KEY (trainer_id) REFERENCES Trainer(trainer_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
DESC Table equipment_maintenance;
 SELECT * FROM equipment_maintenance;

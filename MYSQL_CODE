CREATE DATABASE Gym_Management_System;
USE Gym_Management_System;

# 1 OWNER TABLE( TOP LEVEL)
CREATE TABLE An_Owner (
    owner_id INT PRIMARY KEY AUTO_INCREMENT,
    owner_name VARCHAR(100)
);
SHOW CREATE TABLE AN_OWNER;
SHOW TABLES ;
DESC AN_OWNER;

#2 MANAGER(UNDER OWNER)
CREATE TABLE Manager (
    manager_id INT PRIMARY KEY AUTO_INCREMENT,
    manager_name VARCHAR(100),
    owner_id INT,
    FOREIGN KEY (owner_id) REFERENCES An_Owner(owner_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);
DESC MANAGER;
SHOW TABLES;
SHOW CREATE TABLE MANAGER; 

#3 MEMBER( UNDER MANAGER) 
CREATE TABLE Member (
    member_id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL,
    specialization VARCHAR(100),
    manager_id INT,
    FOREIGN KEY (manager_id) REFERENCES Manager(manager_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
SHOW TABLES;
SHOW CREATE TABLE MEMBER; 
DESC member ;

# 4 TRAINER (UNDER MANAGER)
CREATE TABLE Trainer (
    trainer_id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100),
    specialization VARCHAR(100),
    experience INT,
    manager_id INT,
    FOREIGN KEY (manager_id) REFERENCES Manager(manager_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
SHOW TABLES;
SHOW CREATE TABLE TRAINER;
DESC TRAINER;

# 5 MEMBERSHIP (UNDER MEMBER ,FOR ALL THE MEMBER IN GYM)
CREATE TABLE Membership (
    membership_id INT PRIMARY KEY AUTO_INCREMENT,
    start_date DATE,
    status VARCHAR(50),
    member_id INT,
    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);
DESC MEMBERSHIP;
SHOW TABLES;
SHOW CREATE TABLE MEMBERSHIP;

#6 PAYMENT (UNDER MEMBER)
CREATE TABLE Payment (
    payment_id INT PRIMARY KEY AUTO_INCREMENT,
    payment_date DATE,
    mode VARCHAR(50),
    member_id INT,
    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);
DESC Table Payment ;
SHOW TABLES;
SHOW CREATE TABLE PAYMENT;

#7 WORKOUT (MEMBER AND TRAINER ,BOTH ARE CONNECTED)
CREATE TABLE Workout (
    workout_id INT PRIMARY KEY AUTO_INCREMENT,
    difficulty VARCHAR(50),
    status VARCHAR(50),
    member_id INT,
    trainer_id INT,
    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    FOREIGN KEY (trainer_id) REFERENCES Trainer(trainer_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
SHOW TABLES;
SHOW CREATE TABLE WORKOUT;
DESC workout;


# 8 WORKOUT PLAN (UNDER TRAINER)
CREATE TABLE Workout_Plan (
    plan_id INT PRIMARY KEY AUTO_INCREMENT,
    start_date DATE,
    status VARCHAR(50),
    trainer_id INT,
    FOREIGN KEY (trainer_id) REFERENCES Trainer(trainer_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
DESC Table workout_plan;
SHOW TABLES; 
SHOW CREATE TABLE WORKOUT_PLAN;

#9 DIET( CONNECTED WITH MEMBER AND TRAINER
CREATE TABLE Diet (
    diet_id INT PRIMARY KEY AUTO_INCREMENT,
    calories_target INT,
    member_id INT,
    trainer_id INT,
    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    FOREIGN KEY (trainer_id) REFERENCES Trainer(trainer_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
 SHOW TABLES;
  SHOW CREATE TABLE DIET;
  DESC Table diet;
  
#10 EXERCISE
CREATE TABLE Exercise (
    exercise_id INT PRIMARY KEY AUTO_INCREMENT,
    weight FLOAT,
    calories_burned INT,
    start_date DATE
);
SHOW CREATE TABLE EXERCISE;
show tables;
DESC exercise;

#11 DIET PLAN ( CONNECTED WITH BOTH EXERCISE AND TRAINER)
 CREATE TABLE Diet_Plan (
    diet_plan_id INT PRIMARY KEY AUTO_INCREMENT,
    exercise_id INT,
    sets INT,
    trainer_id INT,
    FOREIGN KEY (exercise_id) REFERENCES Exercise(exercise_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    FOREIGN KEY (trainer_id) REFERENCES Trainer(trainer_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);
DESC table diet_plan;
SHOW TABLES;
SHOW CREATE TABLE DIET_PLAN;

#12 SUPPLEMENTS( UNDER MEMBER)
CREATE TABLE Supplements (
    supplement_id INT PRIMARY KEY AUTO_INCREMENT,
    body_fat FLOAT,
    dosage VARCHAR(100),
    start_date DATE,
    member_id INT,
    FOREIGN KEY (member_id) REFERENCES Member(member_id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);
DESC Table supplements;
SHOW TABLES;
SHOW CREATE TABLE SUPPLEMENTS;

#13 EQUIPMENT MAINTENANCE( CONNECTED WITH THE TRAINER)
CREATE TABLE Equipment_Maintenance (
    maintenance_id INT PRIMARY KEY AUTO_INCREMENT,
    equipment_name VARCHAR(100),
    condition_status VARCHAR(100),
    last_service_date DATE,
    incident_date DATE,
    trainer_id INT,
    FOREIGN KEY (trainer_id) REFERENCES Trainer(trainer_id)
        ON DELETE SET NULL
        ON UPDATE CASCADE
);

SHOW TABLES;
SHOW CREATE TABLE EQUIPMENT_MAINTENANCE;
DESC Table equipment_maintenance;


